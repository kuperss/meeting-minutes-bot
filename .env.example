# ─── 驗證 (前端呼叫後端必備) ────────────────────────────────
# 共享 token,前端首次訪問會要使用者輸入,存 localStorage
# 建議:用 openssl rand -hex 32 產一個長隨機字串
API_TOKEN=change-me-to-a-long-random-string

# 允許的前端來源 (逗號分隔)。GH Pages 網址會長這樣: https://<user>.github.io
# 本機測試也把 http://localhost:8000 加進去
ALLOWED_ORIGINS=https://your-user.github.io,http://localhost:8000

# ─── Google Sheets ─────────────────────────────────────────
# 本機開發:JSON 檔案路徑 / Fly.io:整個 JSON 貼進 Secret (見 README)
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
SPREADSHEET_ID=1T7FMVOkNm8_vKnwu2EcwW3GXly3OyTp-S177YUkxZ1M
TEMPLATE_SHEET_NAME=範本

# ─── NotebookLM ────────────────────────────────────────────
NOTEBOOKLM_STORAGE=./credentials/notebooklm_storage.json

# ─── 部門設定 ──────────────────────────────────────────────
RECORDERS=小明,小華,小美,阿強
NOTEBOOK_RETENTION_DAYS=14

# ─── 伺服器 ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
UPLOADS_DIR=./uploads
